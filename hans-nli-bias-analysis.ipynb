    "    hypothesis = set(clean_text(row[\"sentence2\"]))\n",
    "\n",
    "    # Predict entailment only if hypothesis tokens are a strict subset of premise tokens\n",
    "    return (\n",
    "        \"entailment\"\n",
    "        if hypothesis.issubset(premise)\n",
    "        else \"non-entailment\"\n",
    "    )\n",
